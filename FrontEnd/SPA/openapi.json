  "components": {
    "schemas": {
      "PipelineConfig": {
        "type": "object",
        "properties": {
          "pipeline_id": {
            "type": "integer",
            "title": "流水线编号",
            "description": "用于绑定模板，可采用默认值"
          },
          "descriptions": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "title": "标题"
              },
              "content": {
                "type": "string",
                "title": "详情"
              }
            },
            "title": "流水线描述",
            "description": "文字描述该模板",
            "required": [
              "title"
            ]
          },
          "stages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "title": "流水线阶段配置",
            "description": "连接各阶段StageID"
          },
          "config": {
            "type": "object",
            "properties": {},
            "title": "额外配置"
          }
        },
        "required": [
          "pipeline_id",
          "descriptions",
          "stages"
        ]
      },
      "StageConfig": {
        "type": "object",
        "properties": {
          "stage_id": {
            "type": "integer",
            "title": "阶段编号"
          },
          "descriptions": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "title": "标题"
              },
              "content": {
                "type": "string",
                "title": "详情"
              }
            },
            "title": "阶段描述",
            "description": "简要描述阶段内容",
            "required": [
              "title"
            ]
          },
          "agent_config": {
            "type": "object",
            "properties": {
              "model_provider": {
                "type": "object",
                "properties": {},
                "title": "模型提供商",
                "description": "提供大模型接入"
              },
              "roles": {
                "type": "object",
                "properties": {},
                "title": "模型配置",
                "description": "配置预定信息"
              }
            },
            "required": [
              "model_provider",
              "roles"
            ],
            "title": "Agent配置",
            "description": "配置该阶段Agent信息"
          }
        },
        "required": [
          "stage_id",
          "agent_config",
          "descriptions"
        ]
      },
      "RunSummary": {
        "type": "object",
        "properties": {
          "pipeline_id": {
            "type": "integer",
            "title": "流水线模板编号",
            "description": "连接流水线模板"
          },
          "run_id": {
            "type": "integer",
            "title": "实例编号",
            "description": "标注实例"
          },
          "summary": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "title": "运行状态",
                "description": "running|paused|awaiting_checkpoint|completed|failed|cancelled"
              },
              "current_stage": {
                "type": "string",
                "title": "当前阶段编号",
                "description": "连接stage_id"
              }
            },
            "required": [
              "status",
              "current_stage"
            ],
            "title": "运行概况"
          }
        },
        "required": [
          "pipeline_id",
          "run_id",
          "summary"
        ]
      },
      "Checkpoint": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "integer",
            "title": "实例编号",
            "description": "连接运行实例"
          },
          "checkpoint_id": {
            "type": "integer",
            "title": "检查点编号",
            "description": "标注检查点"
          },
          "reviews": {
            "type": "string",
            "title": "检查点说明",
            "description": "呈现检查点内容"
          },
          "resolution": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "title": "决策",
                "description": "accept|reject"
              },
              "context_id": {
                "type": "integer",
                "description": "反馈内容编号"
              }
            },
            "title": "用户决策",
            "required": [
              "action",
              "context_id"
            ]
          }
        },
        "required": [
          "run_id",
          "checkpoint_id",
          "reviews",
          "resolution"
        ]
      },
      "Context": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "integer",
            "title": "实例编号",
            "description": "绑定运行实例"
          },
          "context_id": {
            "type": "integer",
            "title": "交付内容编号",
            "description": "标注交付内容"
          },
          "type": {
            "type": "string",
            "title": "交付类型",
            "description": "initial|checkpoint"
          },
          "content": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string",
                "title": "用户提示词",
                "description": "可选，提示词内容"
              },
              "refs": {
                "type": "object",
                "properties": {
                  "codebase": {
                    "type": "object",
                    "properties": {},
                    "title": "代码库定位"
                  },
                  "dom": {
                    "type": "object",
                    "properties": {},
                    "title": "网页元素定位"
                  }
                },
                "title": "上下文定位",
                "description": "可选，上下文内容"
              }
            },
            "title": "交付内容",
            "description": "具体交付内容"
          }
        },
        "required": [
          "run_id",
          "context_id",
          "type",
          "content"
        ]
      }
    },
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [],
  "security": []
